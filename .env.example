# LocalAITools 配置文件
# 复制此文件为 .env，然后填入你自己的配置

# ==================== API 连接 ====================
# OpenAI 兼容 API 地址（如 LM Studio、Ollama、vLLM 或云端 API）
OPENAI_BASE_URL=http://localhost:1234/v1
# API 密钥（本地服务可填任意值，云端服务请填入真实 key）
OPENAI_API_KEY=lm-studio

# ==================== 推理设置 ====================
# 是否启用模型的思考/推理模式（true/false），关闭后速度更快适合简单任务
ENABLE_THINKING=true

# ==================== 模型名称 ====================
# 视觉模型（用于图片识别、质量检测）
VISION_MODEL=qwen/qwen3.6-27b
# 视觉模型（思考增强版，用于长截图聊天记录识别）
VISION_MODEL_THINKING=qwen/qwen3.6-35b-a3b-Thinking
# 文本模型（用于翻译、摘要、压缩等）
TEXT_MODEL=qwen/qwen3.5-9b
# 图片重命名模型
RENAME_MODEL=qwen/Qwen3.6-27b
# 压测模型
BENCHMARK_MODEL=qwen3.6-35b-a3b@iq2_xxs

# ==================== Embedding 模型 ====================
# 本地 huggingface embedding 模型路径（留空则在线下载）
EMBEDDING_MODEL_PATH=
# FAISS 向量索引路径
FAISS_INDEX_PATH=faiss_index

# ==================== 并发与重试 ====================
# 默认并行线程数
DEFAULT_WORKERS=2
# 失败重试次数
RETRY_TIMES=2
# 请求超时（秒），用于长任务
REQUEST_TIMEOUT=300
# 请求超时（秒），用于短任务
REQUEST_TIMEOUT_SHORT=60

# ==================== 图片处理 ====================
# 长截图切片高度（像素）
SLICE_HEIGHT=2000
# 切片重叠高度（像素）
OVERLAP=400
# 高质量图片目录名
HIGH_QUALITY_FOLDER=HighQuality
# 低质量/错误图片目录名
LOW_QUALITY_ERRORS_FOLDER=LowQuality_Errors
# 支持的图片格式（逗号分隔）
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tiff
# 按评分重新分类时的比例
TOP_PERCENT=0.05
BOTTOM_PERCENT=0.05

# ==================== 更新 ====================
# 启动时自动 git pull 检查更新（true/false）
AUTO_UPDATE=true

# ==================== 文本处理 ====================
# 聊天记录分块大小（字符数）
DEFAULT_CHUNK_SIZE=20480
# 块间重叠消息数
OVERLAP_MESSAGES=2

# ==================== 翻译 ====================
# 最大上下文 token 数
MAX_CONTEXT_TOKENS=30000
# 源语言
SOURCE_LANG=Chinese
# 目标语言
TARGET_LANG=English
